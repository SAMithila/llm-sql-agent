    "generated_sql": "SELECT c.category_name, SUM(oi.unit_price * oi.quantity * (1 - oi.discount)) AS total_revenue FROM order_items oi JOIN products p ON oi.product_id = p.product_id JOIN categories c ON p.category_id = c.category_id GROUP BY c.category_name LIMIT 100;",
    "sql_confidence": "high",
    "sql_explanation": "This query calculates the total revenue for each product category by joining the order_items, products, and categories tables. It sums up the revenue for each category by multiplying the unit price, quantity, and discount for each order item, and groups the results by category name.",
