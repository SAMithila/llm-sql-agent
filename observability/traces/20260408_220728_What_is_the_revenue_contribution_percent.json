      "categories",
      "order_items"
    ],
    "generated_sql": "SELECT c.category_name, SUM(oi.unit_price * oi.quantity * (1 - oi.discount)) AS category_revenue, (SUM(oi.unit_price * oi.quantity * (1 - oi.discount)) / (SELECT SUM(oi2.unit_price * oi2.quantity * (1 - oi2.discount)) FROM order_items oi2)) * 100 AS revenue_percentage FROM order_items oi JOIN products p ON oi.product_id = p.product_id JOIN categories c ON p.category_id = c.category_id GROUP BY c.category_name LIMIT 100;",
    "sql_confidence": "high",
    "sql_explanation": "This query calculates the total revenue for each product category and then determines what percentage of the total revenue each category contributes. It joins the order_items table with products and categories to group the revenue by category.",
